{
  "buildCommand": "npm run build && npm run build:backend",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install && cd my-backend && npm install",
  "framework": "vite",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
